# Manejo de PDFs

## Validación de Archivos

```typescript
// ✅ GOOD - Validar tipo MIME y extensión
import { BadRequestException } from '@nestjs/common';

const ALLOWED_MIME_TYPES = ['application/pdf'];
const MAX_FILE_SIZE = 10 * 1024 * 1024; // 10MB

async validatePdfFile(file: Express.Multer.File): Promise<void> {
  if (!ALLOWED_MIME_TYPES.includes(file.mimetype)) {
    throw new BadRequestException('Solo se permiten archivos PDF');
  }

  if (file.size > MAX_FILE_SIZE) {
    throw new BadRequestException(`El archivo excede el tamaño máximo de ${MAX_FILE_SIZE / 1024 / 1024}MB`);
  }

  // Validar que realmente es un PDF verificando el header
  const pdfHeader = file.buffer.slice(0, 4).toString();
  if (pdfHeader !== '%PDF') {
    throw new BadRequestException('El archivo no es un PDF válido');
  }
}
```

## Upload de Archivos

```typescript
// ✅ GOOD - Usar FileInterceptor de NestJS
import { FileInterceptor } from '@nestjs/platform-express';
import { UseInterceptors, UploadedFile } from '@nestjs/common';

@Post('upload')
@UseInterceptors(FileInterceptor('file'))
async uploadPdf(
  @UploadedFile() file: Express.Multer.File,
  @Body() createPdfDto: CreatePdfDto,
): Promise<PdfDto> {
  await this.validatePdfFile(file);
  return this.pdfService.create({
    ...createPdfDto,
    filename: file.originalname,
    content: file.buffer,
    mimeType: file.mimetype,
    size: file.size,
  });
}
```

## Almacenamiento

```typescript
// ✅ GOOD - Para archivos grandes, considerar almacenamiento externo
// Opción 1: Sistema de archivos (desarrollo)
const uploadPath = join(process.cwd(), 'uploads', 'pdfs');
await writeFile(join(uploadPath, filename), file.buffer);

// Opción 2: S3/MinIO (producción)
await this.s3Service.upload({
  Bucket: 'pdfs-bucket',
  Key: `pdfs/${filename}`,
  Body: file.buffer,
  ContentType: 'application/pdf',
});

// Opción 3: PostgreSQL bytea (archivos pequeños < 1MB)
const pdf = this.pdfRepository.create({
  filename,
  content: file.buffer, // Buffer se convierte a bytea automáticamente
});
```

## Metadata de PDFs

```typescript
// ✅ GOOD - Extraer y almacenar metadata útil
import * as pdfParse from 'pdf-parse';

async extractPdfMetadata(buffer: Buffer): Promise<PdfMetadata> {
  const data = await pdfParse(buffer);
  return {
    pageCount: data.numpages,
    title: data.info?.Title || null,
    author: data.info?.Author || null,
    subject: data.info?.Subject || null,
    keywords: data.info?.Keywords?.split(',') || [],
    createdAt: data.info?.CreationDate || null,
  };
}
```

## Streaming para Descargas

```typescript
// ✅ GOOD - Usar streaming para archivos grandes
import { Response } from 'express';
import { Readable } from 'stream';

@Get(':id/download')
async downloadPdf(@Param('id') id: string, @Res() res: Response): Promise<void> {
  const pdf = await this.pdfService.findOne(id);
  if (!pdf) {
    throw new NotFoundException(`PDF ${id} no encontrado`);
  }

  res.setHeader('Content-Type', 'application/pdf');
  res.setHeader('Content-Disposition', `attachment; filename="${pdf.filename}"`);
  res.setHeader('Content-Length', pdf.size);

  const stream = Readable.from(pdf.content);
  stream.pipe(res);
}
```

