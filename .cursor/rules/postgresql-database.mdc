# PostgreSQL y TypeORM

## Entidades

```typescript
// ✅ GOOD - Entidad con decoradores TypeORM
import { Entity, PrimaryGeneratedColumn, Column, ManyToOne, JoinColumn, CreateDateColumn, UpdateDateColumn } from 'typeorm';
import { Category } from '../categories/category.entity';

@Entity('pdfs')
export class Pdf {
  @PrimaryGeneratedColumn('uuid')
  id: string;

  @Column({ type: 'varchar', length: 255 })
  filename: string;

  @Column({ type: 'bytea' }) // Para almacenar PDFs en PostgreSQL
  content: Buffer;

  @Column({ type: 'varchar', length: 50 })
  mimeType: string;

  @Column({ type: 'bigint' })
  size: number;

  @ManyToOne(() => Category, { nullable: false, onDelete: 'RESTRICT' })
  @JoinColumn({ name: 'category_id' })
  category: Category;

  @Column({ name: 'category_id' })
  categoryId: string;

  @CreateDateColumn({ name: 'created_at' })
  createdAt: Date;

  @UpdateDateColumn({ name: 'updated_at' })
  updatedAt: Date;
}
```

## Relaciones

```typescript
// ✅ GOOD - Relaciones explícitas con opciones de cascada
@ManyToOne(() => Category, category => category.pdfs, {
  nullable: false,
  onDelete: 'RESTRICT', // Prevenir eliminación si hay PDFs asociados
})
category: Category;

// ✅ GOOD - Relación inversa en Category
@OneToMany(() => Pdf, pdf => pdf.category)
pdfs: Pdf[];
```

## Consultas y Repositorios

```typescript
// ✅ GOOD - Usar QueryBuilder para consultas complejas
async findByCategory(categoryId: string): Promise<Pdf[]> {
  return this.pdfRepository
    .createQueryBuilder('pdf')
    .where('pdf.categoryId = :categoryId', { categoryId })
    .orderBy('pdf.createdAt', 'DESC')
    .getMany();
}

// ✅ GOOD - Usar relaciones de TypeORM para carga eficiente
async findOneWithCategory(id: string): Promise<Pdf | null> {
  return this.pdfRepository.findOne({
    where: { id },
    relations: ['category'],
  });
}

// ✅ GOOD - Transacciones para operaciones múltiples
async createWithCategory(pdfData: CreatePdfDto, categoryId: string): Promise<Pdf> {
  return this.dataSource.transaction(async (manager) => {
    const category = await manager.findOne(Category, { where: { id: categoryId } });
    if (!category) {
      throw new NotFoundException(`Categoría ${categoryId} no encontrada`);
    }
    const pdf = manager.create(Pdf, { ...pdfData, categoryId });
    return manager.save(pdf);
  });
}
```

## Migraciones

- Crear migraciones para todos los cambios de esquema
- Usar nombres descriptivos: `CreatePdfTable`, `AddCategoryIndex`
- Nunca modificar migraciones ya ejecutadas en producción

## Índices

```typescript
// ✅ GOOD - Agregar índices para consultas frecuentes
@Entity('pdfs')
@Index(['categoryId']) // Índice para búsquedas por categoría
@Index(['createdAt']) // Índice para ordenamiento por fecha
export class Pdf {
  // ...
}
```

## Manejo de Datos Binarios

```typescript
// ✅ GOOD - Para PDFs grandes, considerar almacenamiento externo
// Opción 1: Almacenar en PostgreSQL (bytea) - para archivos < 1MB
@Column({ type: 'bytea' })
content: Buffer;

// Opción 2: Almacenar ruta y archivo en sistema de archivos/S3
@Column({ type: 'varchar', length: 500 })
filePath: string;
```
